# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# NEWS_API_KEY: Optional. Your NewsAPI.org token for fetching custom news headlines.
# Go to https://newsapi.org to get a key, and add it in your Secrets configurations.
NEWS_API_KEY=

# NEWSDATA_API_KEY: Optional. Your NewsData.io token for fetching headlines from NewsData.io.
# Go to https://newsdata.io to get a key, and add it in your Secrets configurations.
NEWSDATA_API_KEY=

# NYT_API_KEY: Optional. Your New York Times Article Search API token.
# Go to https://developer.nytimes.com to get a key.
NYT_API_KEY=
